# Environment Variables for URL Shortener (Render Deployment)

# Note: These environment variables are automatically provided by Render
# You don't need to set them manually when deploying to Render

# Server Configuration
PORT=10000

# Database Configuration (Render provides these automatically)
# DATABASE_URL will be in format: mysql://user:password@host:port/database
DATABASE_URL=jdbc:mysql://localhost:3306/urlshortener?createDatabaseIfNotExist=true
DB_USER=urlshortener_user
DB_PASSWORD=your_mysql_password

# For local development, set these in your .env file

# For Railway deployment, these are provided automatically:
# - DATABASE_URL (full JDBC URL)
# - DB_USER (database username)
# - DB_PASSWORD (database password)
# - PORT (assigned by Railway)